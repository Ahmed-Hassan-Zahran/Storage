{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "StorageDb": "Host=localhost;Port=5432;Database=yoxel_storage;Username=postgres;Password=postgres"
  },
  "Storage": {
    "Backend": "Local",
    "Local": {
      "RootPath": "./data/storage"
    },
    "S3": {
      "BucketName": "yoxel-storage",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "ForcePathStyle": false
    }
  },
  "Authentication": {
    "ApiKeys": {
      "dev-key-service-a": { "TenantId": "service-a", "Name": "Service A" },
      "dev-key-service-b": { "TenantId": "service-b", "Name": "Service B" }
    }
  }
}
